# ─────────────────────────────────────────────────────────────
# X Giveaway Hunter — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# XActions session cookie (required)
# How to get it:
#   1. Log into x.com in your browser
#   2. Open DevTools → Application → Cookies → https://x.com
#   3. Copy the value of the "auth_token" cookie
XACTIONS_SESSION_COOKIE=your_auth_token_cookie_here

# ─── Hunt Settings ────────────────────────────────────────────

# Max giveaways to enter per run (default: 10)
MAX_GIVEAWAYS_PER_RUN=10

# Delay between actions in milliseconds (default: 3000 = 3 seconds)
# Increase this to reduce risk of rate limiting / account flags
ACTION_DELAY_MS=3000

# Minimum likes a giveaway post must have to be considered legit (default: 50)
MIN_POST_LIKES=50

# Minimum followers the poster must have (default: 500)
MIN_POSTER_FOLLOWERS=500

# ─── Entry Actions ────────────────────────────────────────────

# Set to "true" to enable each action type
ENABLE_FOLLOW=true
ENABLE_LIKE=true
ENABLE_RETWEET=true
ENABLE_COMMENT=true

# Default comment text when a giveaway asks to "comment below"
# Use {handle} as a placeholder for your own @handle
DEFAULT_COMMENT=🎉 Entering! Good luck everyone!

# ─── Safety ───────────────────────────────────────────────────

# Set to "true" to print actions without actually executing them
DRY_RUN=false

# Max follows per day (safety cap)
MAX_FOLLOWS_PER_DAY=20

# Max likes per day (safety cap)
MAX_LIKES_PER_DAY=50

# Max retweets per day (safety cap)
MAX_RETWEETS_PER_DAY=30

# ─── Logging ──────────────────────────────────────────────────

LOG_LEVEL=info
LOG_FILE=logs/hunter.log
